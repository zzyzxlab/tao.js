{
  "name": "tao.js",
  "version": "0.16.2",
  "main": "index.js",
  "private": true,
  "directories": {
    "doc": "docs",
    "example": "examples"
  },
  "author": "Jeff Hoffer (eudaimos) <jeff@hwgray.com>",
  "license": "Apache-2.0",
  "description": "",
  "scripts": {
    "build": "nx run-many --target=build --all --exclude=patois.*,react19-smoke",
    "clean:build": "nx run-many --target=build:clean --all",
    "test": "nx run-many --target=test --all --exclude=patois.*,react19-smoke",
    "test:coverage": "nx run-many --target=test --all --exclude=patois.*,react19-smoke --coverage",
    "test:coverage:view": "open packages/docs/src/content/coverage/index.html",
    "test:mutation:core": "pnpm --filter @tao.js/core test:mutation",
    "test:mutation:react": "pnpm --filter @tao.js/react test:mutation",
    "test:mutation:socket.io": "pnpm --filter @tao.js/socket.io test:mutation",
    "test:mutation:utils": "pnpm --filter @tao.js/utils test:mutation",
    "test:mutation:router": "pnpm --filter @tao.js/router test:mutation",
    "test:mutation:koa": "pnpm --filter @tao.js/koa test:mutation",
    "test:mutation:routing-core": "pnpm --filter @tao.js/routing-core test:mutation",
    "test:mutation:routing-react-router": "pnpm --filter @tao.js/routing-react-router test:mutation",
    "test:mutation:routing-tanstack-router": "pnpm --filter @tao.js/routing-tanstack-router test:mutation",
    "test:mutation:routing-next": "pnpm --filter @tao.js/routing-next test:mutation",
    "test:watch": "nx run-many --target=test:watch --all --exclude=patois.*,react19-smoke",
    "lint": "nx run-many --target=lint --all --exclude=patois.*,react19-smoke",
    "lint:packages": "nx run-many --target=lint --all",
    "docs:clean": "ls docs | grep -v \"CNAME\" | awk '{print \"docs/\"$1}' | xargs rimraf",
    "docs:build": "nx run docs:build",
    "docs:edit": "nx run docs:book:edit",
    "docs:edits": "$(cd packages/docs && npm run book:edit)",
    "docs:coverage": "npm run test:coverage && nx run docs:coverage && npm run docs:publish",
    "docs:publish": "npm run docs:clean && cp -a packages/docs/dist/ docs",
    "docs:clean:md": "rimraf docs/**/*.md",
    "docs:make": "npm run test:coverage && npm run docs:build && npm run docs:publish && npm run docs:clean:md",
    "docs:make:no-coverage": "npm run docs:build && npm run docs:publish && npm run docs:clean:md",
    "docs:open": "open docs/index.html",
    "chore:clean": "nx run-many --target=clean --all && rimraf ./node_modules && npm install",
    "chore:dependencies:packages": "nx run-many --target=update-deps --all",
    "chore:dependencies:root": "npm update --dev --save",
    "chore:dependencies": "npm run chore:clean && npm run chore:dependencies:root && npm run chore:dependencies:packages",
    "chore:changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "release": "nx release",
    "release:dry": "nx release 0.16.3 --dry-run --first-release --skip-publish",
    "release:publish": "nx release publish",
    "commit": "node scripts/commit.js",
    "commit:validate": "node scripts/validate-commit-msg.js",
    "version": "cz bump",
    "prepare": "husky"
  },
  "type": "module",
  "config": {
    "commitizen": {
      "path": "./scripts/commit.js"
    }
  },
  "lint-staged": {
    "*.{js,json,css,md}": [
      "prettier --write",
      "jest --bail --findRelatedTests --passWithNoTests"
    ]
  },
  "dependencies": {
    "@tao.js/connect": "file:packages/tao-connect",
    "@tao.js/core": "file:packages/tao",
    "@tao.js/feature": "file:packages/tao-feature",
    "@tao.js/koa": "file:packages/koa-tao",
    "@tao.js/path": "file:packages/tao-path",
    "@tao.js/react": "file:packages/react-tao",
    "@tao.js/router": "file:packages/tao-router",
    "@tao.js/routing-core": "file:packages/tao-routing-core",
    "@tao.js/routing-next": "file:packages/tao-routing-next",
    "@tao.js/routing-react-router": "file:packages/tao-routing-react-router",
    "@tao.js/routing-tanstack-router": "file:packages/tao-routing-tanstack",
    "@tao.js/socket.io": "file:packages/tao-socket-io",
    "@tao.js/utils": "file:packages/tao-utils",
    "docs": "file:packages/docs",
    "patois.api": "file:examples/patois.api",
    "patois.web": "file:examples/patois.web"
  },
  "devDependencies": {
    "@babel/cli": "7.1.5",
    "@babel/core": "7.28.0",
    "@babel/eslint-parser": "^7.28.0",
    "@babel/node": "7.2.2",
    "@babel/plugin-syntax-class-properties": "7.0.0",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "7.1.0",
    "@babel/plugin-transform-object-rest-spread": "^7.28.0",
    "@babel/preset-env": "7.28.0",
    "@babel/preset-react": "7.27.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.32.0",
    "@jest/globals": "^30.1.2",
    "@nx/eslint": "23.1.0",
    "@nx/jest": "23.1.0",
    "@nx/js": "23.1.0",
    "@nx/rollup": "23.1.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.2",
    "babel-jest": "30.3.0",
    "babel-plugin-istanbul": "^5.2.0",
    "better-npm-run": "^0.1.1",
    "cheerio": "1.0.0-rc.12",
    "commitizen": "^3.1.2",
    "conventional-changelog": "^3.1.25",
    "conventional-changelog-cli": "^2.2.2",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-babel": "^5.3.1",
    "eslint-plugin-prettier": "^5.5.3",
    "gitbook-updated-cli": "^2.3.4",
    "husky": "^9.1.7",
    "inquirer": "12.9.4",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "lint-staged": "^16.1.5",
    "nodemon": "^1.19.4",
    "nx": "23.1.0",
    "plop": "^2.7.6",
    "prettier": "^3.6.2",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-test-renderer": "^19.2.7",
    "regenerator-runtime": "^0.12.1",
    "rimraf": "^2.7.1",
    "rollup": "4.62.2",
    "rollup-plugin-node-builtins": "^2.1.2",
    "rollup-plugin-node-globals": "^1.4.0",
    "rollup-plugin-peer-deps-external": "^2.2.4"
  },
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad"
}
