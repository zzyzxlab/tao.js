{
  "name": "tao.js",
  "version": "0.16.2",
  "main": "index.js",
  "private": true,
  "directories": {
    "doc": "docs",
    "example": "examples"
  },
  "author": "Jeff Hoffer (eudaimos) <jeff@hwgray.com>",
  "license": "Apache-2.0",
  "description": "",
  "scripts": {
    "build": "nx run-many --target=build --all --exclude=patois.*",
    "clean:build": "nx run-many --target=build:clean --all",
    "test": "nx run-many --target=test --all --exclude=patois.* --passWithNoTests",
    "test:coverage": "nx run-many --target=test:coverage --all --exclude=patois.*",
    "test:coverage:view": "open packages/docs/src/content/coverage/index.html",
    "test:watch": "nx run-many --target=test:watch --all --exclude=patois.*",
    "lint": "nx run-many --target=lint --all --exclude=patois.*",
    "lint:packages": "nx run-many --target=lint --all",
    "docs:clean": "ls docs | grep -v \"CNAME\" | awk '{print \"docs/\"$1}' | xargs rimraf",
    "docs:build": "nx run docs:build",
    "docs:edit": "nx run docs:book:edit",
    "docs:edits": "$(cd packages/docs && npm run book:edit)",
    "docs:coverage": "npm run test:coverage && nx run docs:coverage && npm run docs:publish",
    "docs:publish": "npm run docs:clean && cp -a packages/docs/dist/ docs",
    "docs:clean:md": "rimraf docs/**/*.md",
    "docs:make": "npm run test:coverage && npm run docs:build && npm run docs:publish && npm run docs:clean:md",
    "docs:make:no-coverage": "npm run docs:build && npm run docs:publish && npm run docs:clean:md",
    "docs:open": "open docs/index.html",
    "chore:clean": "nx run-many --target=clean --all && rimraf ./node_modules && npm install",
    "chore:dependencies:packages": "nx run-many --target=update-deps --all",
    "chore:dependencies:root": "npm update --dev --save",
    "chore:dependencies": "npm run chore:clean && npm run chore:dependencies:root && npm run chore:dependencies:packages",
    "chore:changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "commit": "node scripts/commit.js",
    "version": "cz bump",
    "prepare": "husky"
  },
  "type": "module",
  "config": {
    "commitizen": {
      "path": "./scripts/commit.js"
    }
  },
  "lint-staged": {
    "*.{js,json,css,md}": [
      "prettier --write",
      "jest --bail --findRelatedTests"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "packages/*/src/**/*.{js,jsx}",
      "!**/*.story.{js,jsx}",
      "!**/node_modules/**",
      "!**/docs/**",
      "!config/**/*.js",
      "!packages/*/lib/**",
      "!packages/*/test/**"
    ],
    "testRegex": "./(packages|examples)/[^/]+/test/.+\\.m?js$",
    "coverageReporters": [
      "html"
    ],
    "coverageDirectory": "packages/docs/src/content/coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "example.js"
    ],
    "setupFiles": [
      "<rootDir>/config/jest.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/config/setup.js"
    ],
    "transform": {
      "^.+\\.(js|jsx)$": [
        "babel-jest",
        {
          "presets": [
            [
              "@babel/preset-env",
              {
                "targets": {
                  "node": "current"
                }
              }
            ],
            "@babel/preset-react"
          ],
          "plugins": [
            "@babel/plugin-transform-object-rest-spread",
            "@babel/plugin-transform-class-properties"
          ]
        }
      ]
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(cheerio|enzyme|enzyme-to-json|@babel)/)",
      "<rootDir>/(packages|examples)/[^/]+/lib/"
    ],
    "snapshotSerializers": [],
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/config/__mocks__/fileMock.js",
      "\\.(css|less)$": "identity-obj-proxy"
    }
  },
  "dependencies": {
    "@tao.js/connect": "file:packages/tao-connect",
    "@tao.js/core": "file:packages/tao",
    "@tao.js/feature": "file:packages/tao-feature",
    "@tao.js/koa": "file:packages/koa-tao",
    "@tao.js/path": "file:packages/tao-path",
    "@tao.js/react": "file:packages/react-tao",
    "@tao.js/router": "file:packages/tao-router",
    "@tao.js/socket.io": "file:packages/tao-socket-io",
    "@tao.js/utils": "file:packages/tao-utils",
    "docs": "file:packages/docs",
    "patois.api": "file:examples/patois.api",
    "patois.web": "file:examples/patois.web"
  },
  "devDependencies": {
    "@babel/cli": "7.1.5",
    "@babel/core": "7.28.0",
    "@babel/eslint-parser": "^7.28.0",
    "@babel/node": "7.2.2",
    "@babel/plugin-syntax-class-properties": "7.0.0",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "7.1.0",
    "@babel/plugin-transform-object-rest-spread": "^7.28.0",
    "@babel/preset-env": "7.28.0",
    "@babel/preset-react": "7.27.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.32.0",
    "@nx/eslint": "21.3.7",
    "@nx/jest": "21.3.7",
    "@nx/rollup": "21.3.7",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@testing-library/react-hooks": "^5.1.3",
    "babel-jest": "^30.0.5",
    "babel-plugin-istanbul": "^5.2.0",
    "better-npm-run": "^0.1.1",
    "cheerio": "1.0.0-rc.12",
    "commitizen": "^3.1.2",
    "conventional-changelog": "^3.1.25",
    "conventional-changelog-cli": "^2.2.2",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.6",
    "enzyme-to-json": "^3.6.2",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-babel": "^5.3.1",
    "eslint-plugin-prettier": "^5.5.3",
    "gitbook-updated-cli": "^2.3.4",
    "husky": "^9.1.7",
    "inquirer": "12.9.4",
    "jest": "^27.5.1",
    "jest-environment-jsdom": "^27.5.1",
    "jest-enzyme": "^7.1.2",
    "lerna-update-wizard": "^0.9.4",
    "lint-staged": "^16.1.5",
    "nodemon": "^1.19.4",
    "nx": "21.3.7",
    "plop": "^2.7.6",
    "prettier": "^3.6.2",
    "prop-types": "^15.8.1",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-test-renderer": "^16.14.0",
    "react-testing-library": "^5.9.0",
    "regenerator-runtime": "^0.12.1",
    "rimraf": "^2.7.1",
    "rollup": "4.46.0",
    "rollup-plugin-node-builtins": "^2.1.2",
    "rollup-plugin-node-globals": "^1.4.0",
    "rollup-plugin-peer-deps-external": "^2.2.4"
  },
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad"
}
