{
  "name": "@tao.js/opentelemetry",
  "version": "0.18.0",
  "description": "OpenTelemetry exporter for tao.js signal traces — maps @tao.js/telemetry records to OTel spans with causal parentage",
  "homepage": "https://tao.js.org/",
  "repository": {
    "type": "git",
    "url": "https://github.com/zzyzxlab/tao.js.git",
    "directory": "packages/tao-opentelemetry"
  },
  "main": "lib",
  "module": "dist",
  "bundles": {
    "browser": "bundles/browser.umd.js"
  },
  "sideEffects": false,
  "directories": {
    "lib": "dist"
  },
  "files": [
    "lib",
    "dist",
    "bundles"
  ],
  "scripts": {
    "build:clean": "rimraf dist lib bundles",
    "build:package": "rollup --config",
    "build": "npm run build:clean && npm run build:package",
    "test:mutation": "stryker run"
  },
  "author": "eudaimos",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.3.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@tao.js/core": "file:../tao",
    "@tao.js/telemetry": "file:../tao-telemetry"
  }
}
