{
  "name": "@tao.js/telemetry",
  "version": "0.20.0",
  "description": "Telemetry for tao.js signal networks - causal Tracer (a pure Network decoration), TaoLogger, sinks, and W3C trace context helpers",
  "homepage": "https://tao.js.org/",
  "repository": {
    "type": "git",
    "url": "https://github.com/zzyzxlab/tao.js.git",
    "directory": "packages/tao-telemetry"
  },
  "main": "lib",
  "module": "dist",
  "bundles": {
    "browser": "bundles/browser.umd.js"
  },
  "sideEffects": false,
  "directories": {
    "lib": "dist"
  },
  "files": [
    "lib",
    "dist",
    "bundles"
  ],
  "scripts": {
    "build:clean": "rimraf dist lib bundles",
    "build:package": "rollup --config",
    "build": "npm run build:clean && npm run build:package",
    "test:mutation": "stryker run"
  },
  "author": "eudaimos",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@tao.js/core": ">=0.19.0"
  },
  "devDependencies": {
    "@tao.js/core": "file:../tao"
  }
}
